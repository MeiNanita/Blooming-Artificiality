{
    "pack": {
        "description": "Removal of unwanted modded datapacks within the 'Blooming Artificiality'-modpack",
        "pack_format": 15
    },
    "filter": {
        "block": [
            {"namespace": "botanypots", "path": "recipes/.*/soil/.*"},
            {"namespace": "botanypots", "path": "recipes/.*/crop/.*"},

            {"namespace": "flowerseeds", "path": "compat/botanypots/crop/.*"},
            {"namespace": "flowerseedsbop", "path": "compat/botanypots/crop/.*"},
            {"namespace": "croptopia", "path": "botanypots/.*"},

            {"namespace": "minecraft", "path": "advancements/recipes/misc/.*"},
			{"namespace": "minecraft", "path": "recipes/.*_from_.*"},
			{"namespace": "minecraft", "path": "recipes/nuclearcraft_.*_(dust|ore|plate|raw)"},
			{"namespace": "minecraft", "path": "recipes/nuclearcraft_fuel_.*"},
			{"namespace": "minecraft", "path": "recipes/nuclearcraft_.*_sml"},
            {"namespace": "nuclearcraft", "path": "advancements/.*"},
			{"namespace": "nuclearcraft", "path": "recipes/(?!fission_reactor_controller).*"},
            {"namespace": "nuclearcraft", "path": "recipes/fission_reactor_controller/.+_(ox|ni|za)"}
        ]
    }
}